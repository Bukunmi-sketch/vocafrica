{
  "name": "vocafrica",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite --host 0.0.0.0 --port 8080",
    "dev": "vite",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 tsc -b && vite build",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,css,scss,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx,json,css,scss,md}'",
    "typecheck": "tsc --noEmit",
    "build:widget": "vite build --config vite.config.ts",
    "dev:widget": "vite build --config vite.config.ts --watch",
    "preview": "vite",
    "check": "tsc --noEmit",
    "test": "NODE_OPTIONS=--max-old-space-size=8192 vitest",
    "test:run": "NODE_OPTIONS=--max-old-space-size=8192 vitest run",
    "test:run:ci": "node scripts/test-run-ci.mjs",
    "test:run:ci:force": "node scripts/force-exit.js",
    "test:coverage": "NODE_OPTIONS=--max-old-space-size=8192 vitest run --coverage",
    "prepare": "husky",
    "precommit": "lint-staged && npm run check && npm run build"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "npx prettier --write"
    ],
    "src/**/*.{json,css,scss,md}": [
      "npx prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@headlessui/react": "^2.2.9",
    "@react-oauth/google": "^0.12.1",
    "ai": "^4.3.16",
    "appointment-picker": "^2.0.0",
    "axios": "^1.7.9",
    "currency-list": "^1.0.8",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dayjs": "^1.11.13",
    "dlv": "^1.1.3",
    "dompurify": "^3.2.6",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.4.1",
    "jsvectormap": "^1.5.3",
    "lodash": "^4.17.21",
    "lucide-react": "^0.475.0",
    "luxon": "^3.7.1",
    "ms": "^2.1.3",
    "react": "^18.3.1",
    "react-apexcharts": "^1.4.1",
    "react-datepicker": "^8.4.0",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "react-flatpickr": "^4.0.10",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.4.0",
    "react-is": "^19.1.1",
    "react-loader-spinner": "^6.1.6",
    "react-phone-input-2": "^2.15.1",
    "react-phone-input-2-css": "^1.0.0",
    "react-router": "^7.13.0",
    "react-router-dom": "^7.1.1",
    "react-select": "^5.10.1",
    "react-spinners": "^0.15.0",
    "react-time-picker": "^7.0.0",
    "react-toastify": "^9.1.3",
    "react-tooltip": "^5.30.0",
    "recharts": "^3.1.0",
    "socket.io-client": "^4.8.3",
    "sort-by": "^0.0.2",
    "swiper": "^11.2.5",
    "to-fast-properties": "^4.0.0",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@types/chai": "^5.0.1",
    "@types/file-saver": "^2.0.7",
    "@types/json2csv": "^5.0.7",
    "@types/jspdf": "^1.3.3",
    "@types/lodash": "^4.17.16",
    "@types/luxon": "^3.7.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.12.0",
    "@types/react": "^18.3.18",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-big-calendar": "^1.16.1",
    "@types/react-dom": "^18.3.5",
    "@types/tailwindcss": "^3.0.11",
    "@types/testing-library__react": "^10.2.0",
    "@types/xlsx": "^0.0.35",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.21",
    "chai": "^4.5.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.4.3",
    "mocha": "^10.8.2",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "rollup": "^4.45.0",
    "sass": "^1.92.1",
    "tailwindcss": "^3.4.17",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^7.0.6",
    "vite-plugin-mkcert": "^1.17.9",
    "vitest": "^2.1.9"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.50.0"
  }
}
